# ─────────────────────────────────────────
# NendPlay Backend — Environment Variables
# Copy this to .env and fill in values
# NEVER commit .env to GitHub
# ─────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/nendplay?retryWrites=true&w=majority

# JWT
JWT_ACCESS_SECRET=your_access_secret
JWT_REFRESH_SECRET=your_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081,https://nendplay.com,https://www.nendplay.com

# Cookie
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Cloudinary — https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Media Limits
MAX_VIDEO_SIZE_MB=500
MAX_AUDIO_SIZE_MB=50
MAX_IMAGE_SIZE_MB=10

# Global video provider / direct uploads
# Use Bunny as primary and Mux as fallback for long-form video.
VIDEO_STORAGE_PROVIDER=cloudinary
VIDEO_FALLBACK_PROVIDER=
DIRECT_UPLOAD_ENABLED=false
BUNNY_STREAM_LIBRARY_ID=your_bunny_stream_library_id
BUNNY_STREAM_API_KEY=your_bunny_stream_api_key
BUNNY_STREAM_HOSTNAME=your-library.b-cdn.net
BUNNY_TUS_EXPIRATION_SECONDS=86400
MUX_TOKEN_ID=your_mux_token_id
MUX_TOKEN_SECRET=your_mux_token_secret
MUX_CORS_ORIGIN=http://localhost:5173
MUX_PLAYBACK_POLICY=public
MUX_VIDEO_QUALITY=basic

# Paystack — https://dashboard.paystack.com → Settings → API
PAYSTACK_SECRET_KEY=your_paystack_test_secret_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# Flutterwave — https://dashboard.flutterwave.com → Settings → API
FLUTTERWAVE_SECRET_KEY=your_flutterwave_test_secret_key
FLUTTERWAVE_WEBHOOK_SECRET=your_flutterwave_webhook_secret

# Frontend URL (for payment redirect after payment)
CLIENT_URL=http://localhost:5173

# Email provider for password reset emails
# Resend: https://resend.com
RESEND_API_KEY=your_resend_api_key
PASSWORD_RESET_FROM=NendPlay <noreply@yourdomain.com>
EMAIL_FROM=NendPlay <support@yourdomain.com>
PASSWORD_RESET_RETURN_TOKEN=false

# Google sign-in OAuth client ids
# Keep GOOGLE_AUTH_ENABLED=false while Gmail registration/sign-in is disabled.
GOOGLE_AUTH_ENABLED=false
GOOGLE_WEB_CLIENT_ID=your_google_web_oauth_client_id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your_google_android_oauth_client_id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your_google_ios_oauth_client_id.apps.googleusercontent.com

# AdMob rewarded ads server-side verification
# Use this callback URL in AdMob after your backend is deployed on HTTPS:
# https://your-api-domain.com/api/rewards/admob/ssv
ADMOB_SSV_KEYS_URL=https://www.gstatic.com/admob/reward/verifier-keys.json
