PORT=5000
HOST=0.0.0.0
NODE_ENV=production

MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/nendplay?retryWrites=true&w=majority

JWT_ACCESS_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

ALLOWED_ORIGINS=https://nendplay.com,https://www.nendplay.com,https://nendplay-web.onrender.com
COOKIE_SECURE=true
COOKIE_SAME_SITE=none

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

MAX_VIDEO_SIZE_MB=500
MAX_AUDIO_SIZE_MB=50
MAX_IMAGE_SIZE_MB=10

VIDEO_STORAGE_PROVIDER=bunny
VIDEO_FALLBACK_PROVIDER=mux
DIRECT_UPLOAD_ENABLED=true
BUNNY_STREAM_LIBRARY_ID=your_bunny_stream_library_id
BUNNY_STREAM_API_KEY=your_bunny_stream_api_key
BUNNY_STREAM_HOSTNAME=your-library.b-cdn.net
BUNNY_TUS_EXPIRATION_SECONDS=86400
MUX_TOKEN_ID=your_mux_token_id
MUX_TOKEN_SECRET=your_mux_token_secret
MUX_CORS_ORIGIN=https://nendplay.com
MUX_PLAYBACK_POLICY=public
MUX_VIDEO_QUALITY=basic

NEWS_API_KEY=your_news_api_key

PAYSTACK_SECRET_KEY=your_paystack_live_secret_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret
FLUTTERWAVE_SECRET_KEY=your_flutterwave_live_secret_key
FLUTTERWAVE_WEBHOOK_SECRET=your_flutterwave_webhook_secret

OPAY_MERCHANT_ID=your_opay_merchant_id
OPAY_PUBLIC_KEY=your_opay_public_key
OPAY_SECRET_KEY=your_opay_secret_key
OPAY_INITIALIZE_URL=your_opay_checkout_create_url
OPAY_VERIFY_URL=your_opay_payment_status_url

PALMPAY_APP_ID=your_palmpay_app_id
PALMPAY_MERCHANT_ID=your_palmpay_merchant_id
PALMPAY_PUBLIC_KEY=your_palmpay_public_key
PALMPAY_SECRET_KEY=your_palmpay_secret_key
PALMPAY_INITIALIZE_URL=your_palmpay_checkout_create_url
PALMPAY_VERIFY_URL=your_palmpay_payment_status_url

CLIENT_URL=https://nendplay.com

RESEND_API_KEY=your_resend_api_key
PASSWORD_RESET_FROM=NendPlay <support@nendplay.com>
EMAIL_FROM=NendPlay <support@nendplay.com>
PASSWORD_RESET_RETURN_TOKEN=false

GOOGLE_AUTH_ENABLED=false
GOOGLE_WEB_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

ADMOB_SSV_KEYS_URL=https://www.gstatic.com/admob/reward/verifier-keys.json
